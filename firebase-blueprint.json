{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "An appointment booking for a service.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Full name of the client." },
        "phoneNumber": { "type": "string", "description": "Phone number of the client." },
        "email": { "type": "string", "format": "email", "description": "Email address of the client." },
        "serviceId": { "type": "string", "description": "ID of the selected service." },
        "serviceName": { "type": "string", "description": "Name of the selected service." },
        "date": { "type": "string", "format": "date", "description": "Date of the appointment (YYYY-MM-DD)." },
        "timeSlot": { "type": "string", "description": "Selected time slot." },
        "notes": { "type": "string", "description": "Additional notes from the client." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the booking was created." }
      },
      "required": ["fullName", "phoneNumber", "serviceId", "date", "timeSlot"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of all appointment bookings."
    }
  }
}
